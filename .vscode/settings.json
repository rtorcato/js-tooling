{
	"editor.defaultFormatter": "biomejs.biome",
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.organizeImports": "never"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[mjs]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"files.associations": {
		"pre-commit": "shellscript",
		"commit-msg": "shellscript",
		".husky/*": "shellscript"
	},
	"vitest.configSearchPatternInclude": "vitest.config.mjs",
	"vitest.configSearchPatternExclude": "**/{node_modules,dist,.git,tooling}/**"
}
